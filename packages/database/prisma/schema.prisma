generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Receipt {
  id           String     @id @default(cuid())
  merchant     String
  purchaseDate String
  purchaseTime String?
  currency     String     @default("EUR")
  notes        String?
  totalCents   Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lineItems    LineItem[]

  @@index([purchaseDate, id])
}

model LineItem {
  id             String  @id @default(cuid())
  receiptId      String
  receipt        Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description    String
  quantityMilli  Int?
  unitPriceCents Int?
  lineTotalCents Int
  position       Int

  @@unique([receiptId, position])
  @@index([receiptId])
}
