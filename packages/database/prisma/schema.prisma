generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Canonical merchant brand or group, for example `EDEKA`.
model MerchantBrand {
  id             String          @id @default(cuid())
  name           String
  normalizedName String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stores         MerchantStore[]
  receipts       Receipt[]

  @@index([normalizedName, id])
}

/// A specific store belonging to exactly one brand, for example `EDEKA Müller`.
model MerchantStore {
  id                   String        @id @default(cuid())
  brandId              String
  brand                MerchantBrand @relation(fields: [brandId], references: [id], onDelete: Restrict)
  name                 String
  normalizedName       String
  street               String?
  postalCode           String?
  city                 String?
  normalizedAddressKey String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  receipts             Receipt[]

  /// Same-name stores are allowed at different known addresses; two
  /// address-less same-name stores must be disambiguated by display name.
  @@unique([brandId, normalizedName, normalizedAddressKey])
  /// Target of the compound receipt relation that keeps store and brand consistent.
  @@unique([id, brandId])
  @@index([brandId, normalizedName, id])
}

model Receipt {
  id              String           @id @default(cuid())
  merchantRaw     String
  merchantBrandId String?
  merchantStoreId String?
  merchantBrand   MerchantBrand?   @relation(fields: [merchantBrandId], references: [id], onDelete: Restrict)
  merchantStore   MerchantStore?   @relation(fields: [merchantStoreId, merchantBrandId], references: [id, brandId], onDelete: Restrict)
  purchaseDate    String
  purchaseTime    String?
  currency        String           @default("EUR")
  notes           String?
  totalCents      Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lineItems       LineItem[]
  document        ReceiptDocument?

  @@index([purchaseDate, id])
  @@index([merchantBrandId])
  @@index([merchantStoreId])
}

model ReceiptDocument {
  id                          String            @id @default(cuid())
  receiptId                   String            @unique
  receipt                     Receipt           @relation(fields: [receiptId], references: [id], onDelete: Restrict)
  relativePath                String            @unique
  originalFilename            String?
  mediaType                   String
  byteSize                    Int
  sha256                      String
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  normalizationStatus         String            @default("pending")
  normalizationError          String?
  normalizationProfileVersion String?
  normalizationRenderer       String?
  normalizationRequestedAt    DateTime          @default(now())
  normalizationStartedAt      DateTime?
  normalizationCompletedAt    DateTime?
  pages                       ReceiptPage[]
  normalizationJob            NormalizationJob?

  @@unique([sha256, byteSize])
}

model ReceiptPage {
  id             String          @id @default(cuid())
  documentId     String
  document       ReceiptDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)
  pageNumber     Int
  totalPages     Int
  relativePath   String          @unique
  mediaType      String
  byteSize       Int
  width          Int
  height         Int
  sha256         String
  profileVersion String
  renderer       String
  createdAt      DateTime        @default(now())

  @@unique([documentId, pageNumber])
}

model NormalizationJob {
  id             String          @id @default(cuid())
  documentId     String          @unique
  document       ReceiptDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)
  status         String          @default("pending")
  profileVersion String
  attempts       Int             @default(0)
  availableAt    DateTime        @default(now())
  claimedAt      DateTime?
  lastError      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status, availableAt, id])
}

/// Durable retry record for filesystem cleanup that could not complete after a
/// successful metadata transition. Paths remain internal and storage-relative.
model DocumentFileCleanup {
  id           String   @id @default(cuid())
  relativePath String   @unique
  attempts     Int      @default(0)
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LineItem {
  id             String  @id @default(cuid())
  receiptId      String
  receipt        Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description    String
  quantityMilli  Int?
  unitPriceCents Int?
  lineTotalCents Int
  position       Int

  @@unique([receiptId, position])
  @@index([receiptId])
}
